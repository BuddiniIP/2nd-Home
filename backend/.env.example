# Backend environment example
# Copy this file to `.env` and fill in real values locally. Do NOT commit `.env` with real secrets.

PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/secondhome?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Stripe (test mode keys — get yours from https://dashboard.stripe.com/test/apikeys)
# No signup needed — Stripe test keys work instantly
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
