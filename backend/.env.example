# Backend environment variables
# Copy this file to `.env` (same directory) and fill in real values.
# NEVER commit `.env` files with real secrets.

PORT=5000

# ---------- MongoDB ----------
# Get a free cluster at https://cloud.mongodb.com
# Create a database user, then use the connection string below.
# Replace <username>, <password>, and <dbname>.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ---------- JWT ----------
# Generate a random secret: run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=replace_with_random_hex_string
JWT_EXPIRES_IN=7d

# ---------- Frontend URL (for CORS) ----------
FRONTEND_URL=http://localhost:5173

# ---------- Cloudinary (for image uploads) ----------
# 1. Go to https://cloudinary.com/register — free account (no credit card)
# 2. From the Dashboard, copy:
#    - Cloud name
#    - API Key
#    - API Secret
# 3. Paste below. If these are empty, the app falls back to local disk storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Stripe ----------
# 1. Go to https://dashboard.stripe.com/register — create a free Stripe account
# 2. Go to https://dashboard.stripe.com/test/apikeys
# 3. Copy your "Secret key" (starts with sk_test_...) and paste below
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# 4. In the same Stripe Dashboard, go to Developers → Webhooks → Add endpoint
#    - Endpoint URL: http://localhost:5000/api/payments/webhook
#    - Events to listen to: checkout.session.completed
#    - After creating, copy the "Signing secret" (starts with whsec_...) and paste below
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret
