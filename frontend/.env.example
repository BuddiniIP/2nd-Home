# Frontend environment variables
# Copy this file to `.env` in the frontend/ directory.

# Backend API base URL (default: http://localhost:5000)
VITE_API_BASE=http://localhost:5000

# ---------- Gemini API Key (optional, unused in current code) ----------
# GEMINI_API_KEY=

# ---------- Google Maps Embed API Key (optional) ----------
# The listing detail page shows a map. Without a key it falls back to a placeholder.
# To get a key:
#   1. Go to https://console.cloud.google.com — create or select a project
#   2. Enable the "Maps Embed API" from  https://console.cloud.google.com/apis/library/maps-embed-backend.googleapis.com
#   3. Go to https://console.cloud.google.com/apis/credentials → Create Credentials → API Key
#   4. Copy the key and paste below (no restrictions needed for local dev, but restrict in production)
#   5. (Optional but recommended) Under "Application restrictions", choose "HTTP referrers" and add:
#      http://localhost:5173/*, http://localhost:3000/*
VITE_GOOGLE_MAPS_KEY=
